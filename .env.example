# ============================================
# Biography Library - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to git!

# ------------------
# Database (Supabase)
# ------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ------------------
# AI Provider
# ------------------
# Select AI provider: 'claude' or 'euria' (default: claude)
# Frontend provider selection (optional, determines which provider class to use)
NEXT_PUBLIC_AI_PROVIDER=claude

# Edge Function provider (this is what actually determines the AI backend)
# Set this in Supabase Edge Function secrets to: 'claude' or 'euria'
# AI_PROVIDER=claude

# Claude/Anthropic (Default provider)
# Set this in Supabase Edge Function secrets
# ANTHROPIC_API_KEY=your_claude_api_key_here

# Infomaniak Euria (Alternative provider)
# Set these in Supabase Edge Function secrets when ready to use Euria
# EURIA_API_KEY=your_euria_api_key_here
# EURIA_API_URL=https://api.infomaniak.com/1/ai/chat

# Infomaniak AI Tools (Mistral3 - OpenAI-compatible endpoint)
# Use this for Infomaniak AI integration with OpenAI-compatible API
INFOMANIAK_AI_ENDPOINT=https://api.infomaniak.com/2/ai/107001/openai/v1/chat/completions
INFOMANIAK_AI_MODEL=mistral3
INFOMANIAK_AI_TOKEN=your_token_here

# ------------------
# Application
# ------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ------------------
# Optional Services
# ------------------
# Future: W3C Verifiable Credentials
# DID_PRIVATE_KEY=
# DID_PUBLIC_KEY=
