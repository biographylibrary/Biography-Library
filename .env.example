# ============================================
# Biography Library — Environment Variables
# ============================================
# Copy this file to .env.local for local development.
# Never commit .env.local to git.
# In production these are set as environment variables on the host
# (Infomaniak Jelastic) or as Supabase Edge Function secrets.

# ------------------
# Supabase (required by the Next.js app)
# ------------------
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Server-only — required for /api/review/submit, /api/publication/*, /api/agents/*
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ------------------
# Infomaniak AI — Next.js API route (/api/review/submit)
# ------------------
# Read server-side only (no NEXT_PUBLIC_ prefix).
# The /api/review/submit route calls Infomaniak directly, bypassing Edge Functions.
# Endpoint format: https://api.infomaniak.com/2/ai/<product_id>/openai/v1/chat/completions
INFOMANIAK_AI_ENDPOINT=https://api.infomaniak.com/2/ai/YOUR_PRODUCT_ID/openai/v1/chat/completions
INFOMANIAK_AI_TOKEN=your_infomaniak_ai_token_here
# Model used by the review/submit route (screening). See GET .../openai/v1/models on your product.
INFOMANIAK_AI_MODEL=google/gemma-4-31B-it
# OpenAI-compatible API root (without /chat/completions). Derived from INFOMANIAK_AI_ENDPOINT if unset.
# INFOMANIAK_AI_BASE_URL=https://api.infomaniak.com/2/ai/YOUR_PRODUCT_ID/openai/v1

# ------------------
# Application
# ------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Values: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Agent platform (Next.js /api/agents/*)
# AGENT_MODEL_COACH=google/gemma-4-31B-it
# AGENT_MODEL_ONBOARDING=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-FP8
# AGENT_MODEL_ONBOARDING=google/gemma-4-31B-it
# AGENT_EMBEDDING_MODEL=bge_multilingual_gemma2
# AGENT_SKIP_MODEL_CATALOG=true
# AGENT_DAILY_LIMIT=80
# AGENT_BURST_LIMIT=10

# ------------------
# Echo voice — Mistral Voxtral TTS (see docs/ECHO_VOICE.md)
# ------------------
# MISTRAL_API_KEY=
# ECHO_TTS_MODEL=voxtral-mini-tts-2603
# Optional voice slugs from La Plateforme (list via Mistral API /audio/voices)
# Defaults to en_paul_neutral for all UI languages if unset
# ECHO_TTS_VOICE=en_paul_neutral
# ECHO_TTS_VOICE_IT=en_paul_neutral
# ECHO_TTS_VOICE_EN=en_paul_neutral
# ECHO_TTS_VOICE_FR=en_paul_neutral
# ECHO_TTS_VOICE_DE=en_paul_neutral

# ------------------
# Supabase Edge Function secrets
# ------------------
# These are NOT .env variables — set them via the Supabase dashboard or MCP tool.
# Listed here for reference only; they are never read by the Next.js process.
#
# SUPABASE_URL                  — auto-populated by the Supabase runtime
# SUPABASE_ANON_KEY             — auto-populated by the Supabase runtime
# SUPABASE_SERVICE_ROLE_KEY     — auto-populated by the Supabase runtime
# INFOMANIAK_AI_TOKEN           — same token as above
# INFOMANIAK_AI_ENDPOINT        — same endpoint URL as above
# INFOMANIAK_AI_MODEL_PRIMARY   — ai-assistant (default: google/gemma-4-31B-it)
# INFOMANIAK_AI_MODEL_FALLBACK  — ai-assistant fallback (default: mistralai/Mistral-Small-4-119B-2603)
# INFOMANIAK_AI_MODEL_HELP_PRIMARY  — help-assistant (default: nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-FP8)
# INFOMANIAK_AI_MODEL_HELP_FALLBACK — help-assistant fallback (default: mistralai/Ministral-3-14B-Instruct-2512)
# AI_RATE_LIMIT                 — per-user per-minute request cap (default: 5)
# AI_DAILY_LIMIT                — per-user daily cap (default: 40)
# AI_WEEKLY_LIMIT               — per-user weekly cap (default: 200)
