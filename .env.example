# ============================================
# Biography Library - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to git!

# ------------------
# Database (Supabase)
# ------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ------------------
# AI Provider
# ------------------
# Production (Infomaniak Euria) - not yet implemented
EURIA_API_KEY=your_euria_api_key_here
EURIA_API_URL=https://api.infomaniak.com/1/ai/chat

# Development fallback (Claude/Anthropic) - current implementation
ANTHROPIC_API_KEY=your_claude_api_key_here

# ------------------
# Application
# ------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ------------------
# Optional Services
# ------------------
# Future: W3C Verifiable Credentials
# DID_PRIVATE_KEY=
# DID_PUBLIC_KEY=
