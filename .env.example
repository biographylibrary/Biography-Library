# ============================================
# Biography Library - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to git!

# ------------------
# Database (Supabase)
# ------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ------------------
# AI Provider
# ------------------
# Infomaniak AI Tools (Mistral3 - OpenAI-compatible endpoint)
# This is the primary and only AI provider for this application
# Set these in Supabase Edge Function secrets:
# - INFOMANIAK_AI_TOKEN (required)
# - INFOMANIAK_AI_ENDPOINT (optional, defaults to below)
# - INFOMANIAK_AI_MODEL (optional, defaults to mistral3)

INFOMANIAK_AI_ENDPOINT=https://api.infomaniak.com/2/ai/107001/openai/v1/chat/completions
INFOMANIAK_AI_MODEL=mistral3
INFOMANIAK_AI_TOKEN=your_token_here

# ------------------
# Application
# ------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ------------------
# Optional Services
# ------------------
# Future: W3C Verifiable Credentials
# DID_PRIVATE_KEY=
# DID_PUBLIC_KEY=
